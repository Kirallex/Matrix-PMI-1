{
    "dataRoles": [
        {
            "name": "Rows",
            "displayName": "Rows",
            "displayNameKey": "Visual_Rows",
            "kind": "Grouping"
        },
        {
            "name": "Columns",
            "displayName": "Columns",
            "displayNameKey": "Visual_Columns",
            "kind": "Grouping"
        },
        {
            "name": "Value",
            "displayName": "Value",
            "displayNameKey": "Visual_Values",
            "kind": "Measure"
        }
    ],
    "dataViewMappings": [
        {
            "matrix": {
                "rows": {
                    "for": {
                        "in": "Rows"
                    },
                "dataReductionAlgorithm": {
                        "window": {
                        "count": 10000
                        }
                }
                },
                "columns": {
                    "for": {
                        "in": "Columns"
                    },
                "dataReductionAlgorithm": {
                        "top": {
                        "count": 1000
                        }
                }
                },
                "values": {
                    "select": [
                        {
                            "for": {
                                "in": "Value"
                            }
                        }
                    ]
                }
            }
        }
    ],
    "objects": {
        "subTotals": {
            "displayName": "Subtotals",
            "properties": {
                "rowSubtotals": {
                    "type": {
                        "bool": true
                    },
                    "displayName": "Row subtotals",
                    "description": "Show subtotals for all row groups",
                    "suppressFormatPainterCopy": true
                },
                "perRowLevel": {
                    "displayName": "Per row level",
                    "type": {
                        "bool": true
                    },
                    "suppressFormatPainterCopy": true
                },
                "columnSubtotals": {
                    "type": {
                        "bool": true
                    },
                    "displayName": "Column subtotals",
                    "description": "Show subtotals for all column groups",
                    "suppressFormatPainterCopy": true
                },
                "perColumnLevel": {
                    "displayName": "Per column level",
                    "type": {
                        "bool": true
                    },
                    "suppressFormatPainterCopy": true
                },
                "levelSubtotalEnabled": {
                    "type": {
                        "bool": true
                    }
                },
                "grandTotal": {
                    "type": {
                        "bool": true
                    },
                    "displayName": "Grand total",
                    "description": "Show grand total row"
                },
                "nonGrandTotal": {
                    "type": {
                        "bool": true
                    },
                    "displayName": "Nongrand total",
                    "description": "Show Nongrand total row"
                }
            }
        },
        "hideEmptyCols": {
            "displayName": "Hide Empty Columns",
            "properties": {
                "hideColsLabel": {
                    "displayName": "Hide Empty Columns",
                    "type": {
                        "bool": true
                    }
                }
            }
        },
        "grid": {
            "displayName": "Grid",
            "properties": {
                "horizontalColor": { "type": { "fill": { "solid": { "color": true } } } },
                "horizontalWidth": { "type": { "numeric": true } },
                "verticalColor": { "type": { "fill": { "solid": { "color": true } } } },
                "verticalWidth": { "type": { "numeric": true } },
                "borderSection": {
                    "type": {
                        "enumeration": [
                            { "value": "all", "displayName": "All" },
                            { "value": "columnHeader", "displayName": "Column Header" },
                            { "value": "rowHeader", "displayName": "Row Header" },
                            { "value": "values", "displayName": "Values Section" }
                        ]
                    }
                },
                "borderPositionTop": { "type": { "bool": true } },
                "borderPositionBottom": { "type": { "bool": true } },
                "borderPositionLeft": { "type": { "bool": true } },
                "borderPositionRight": { "type": { "bool": true } },
                "borderColor": { "type": { "fill": { "solid": { "color": true } } } },
                "borderWidth": { "type": { "numeric": true } },
                "rowPadding": { "type": { "numeric": true } },
                "globalFontSize": { "type": { "numeric": true } }
            }
        },
        "values": {
            "displayName": "Values",
            "properties": {
                "fontFamily": {
                    "type": { "formatting": { "fontFamily": true } }
                },
                "fontSize": {
                    "type": { "formatting": { "fontSize": true } }
                },
                "bold": {
                    "type": { "bool": true }
                },
                "italic": {
                    "type": { "bool": true }
                },
                "underline": {
                    "type": { "bool": true }
                },
                "textColor": {
                    "type": { "fill": { "solid": { "color": true } } }
                },
                "backgroundColor": {
                    "type": { "fill": { "solid": { "color": true } } }
                },
                "altTextColor": {
                    "type": { "fill": { "solid": { "color": true } } }
                },
                "altBackgroundColor": {
                    "type": { "fill": { "solid": { "color": true } } }
                }
            }
        },
        "columnHeaders": {
            "displayName": "Column Headers",
            "properties": {
                "fontFamily": { "type": { "formatting": { "fontFamily": true } } },
                "fontSize": { "type": { "formatting": { "fontSize": true } } },
                "bold": { "type": { "bool": true } },
                "italic": { "type": { "bool": true } },
                "underline": { "type": { "bool": true } },
                "textColor": { "type": { "fill": { "solid": { "color": true } } } },
                "backgroundColor": { "type": { "fill": { "solid": { "color": true } } } },
                "headerAlignment": { "type": { "enumeration": [] } },
                "titleAlignment": { "type": { "enumeration": [] } }
