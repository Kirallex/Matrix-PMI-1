        "rowHeaders": {
            "displayName": "Row Headers",
            "properties": {
                "fontFamily": { "type": { "formatting": { "fontFamily": true } } },
                "fontSize": { "type": { "formatting": { "fontSize": true } } },
                "bold": { "type": { "bool": true } },
                "italic": { "type": { "bool": true } },
                "underline": { "type": { "bool": true } },
                "textColor": { "type": { "fill": { "solid": { "color": true } } } },
                "backgroundColor": { "type": { "fill": { "solid": { "color": true } } } },
                "textAlignment": { "type": { "enumeration": [] } }
            }
        },
        "columnGrandTotal": {
        "displayName": "Column grand total",
        "properties": {
            "fontFamily": { "type": { "formatting": { "fontFamily": true } } },
            "fontSize": { "type": { "formatting": { "fontSize": true } } },
            "bold": { "type": { "bool": true } },
            "italic": { "type": { "bool": true } },
            "underline": { "type": { "bool": true } },
            "textColor": { "type": { "fill": { "solid": { "color": true } } } },
            "backgroundColor": { "type": { "fill": { "solid": { "color": true } } } },
            "applyToLabels": { "type": { "bool": true } }
        }
    },

    "rowGrandTotal": {
        "displayName": "Row grand total",
        "properties": {
            "fontFamily": { "type": { "formatting": { "fontFamily": true } } },
            "fontSize": { "type": { "formatting": { "fontSize": true } } },
            "bold": { "type": { "bool": true } },
            "italic": { "type": { "bool": true } },
            "underline": { "type": { "bool": true } },
            "textColor": { "type": { "fill": { "solid": { "color": true } } } },
            "backgroundColor": { "type": { "fill": { "solid": { "color": true } } } },
            "applyToLabels": { "type": { "bool": true } }
        }
    }
    },
    "subtotals": {
        "matrix": {
            "rowSubtotals": {
                "propertyIdentifier": {
                    "objectName": "subTotals",
                    "propertyName": "rowSubtotals"
                },
                "defaultValue": true
            },
            "rowSubtotalsPerLevel": {
                "propertyIdentifier": {
                    "objectName": "subTotals",
                    "propertyName": "perRowLevel"
                },
                "defaultValue": false
            },
            "columnSubtotals": {
                "propertyIdentifier": {
                    "objectName": "subTotals",
                    "propertyName": "columnSubtotals"
                },
                "defaultValue": true
            },
            "columnSubtotalsPerLevel": {
                "propertyIdentifier": {
                    "objectName": "subTotals",
                    "propertyName": "perColumnLevel"
                },
                "defaultValue": false
            },
            "levelSubtotalEnabled": {
                "propertyIdentifier": {
                    "objectName": "subTotals",
                    "propertyName": "levelSubtotalEnabled"
                },
                "defaultValue": true
            }
        }
    },
    
    "privileges": [
        {
            "name": "ExportContent",
            "essential": true
